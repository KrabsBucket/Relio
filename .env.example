# PrismClaw Configuration
# Copy to .env and fill in your keys

# Gemini API (primary AI — https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Groq API (FREE Whisper transcription + Llama fallback — https://console.groq.com)
GROQ_API_KEY=

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# User identity (used in greetings and digest)
USER_NAME=

# Browser for OAuth (set to 'start' on Windows, 'open' on macOS, 'xdg-open' on Linux)
OAUTH_BROWSER=start

# Google Calendar uses credentials.json (OAuth2) in project root
